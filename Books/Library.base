views:
  - type: cards
    name: Table
    filters:
      and:
        - file.folder == "Books/Books_Review"
    groupBy:
      property: tags
      direction: ASC
    order:
      - file.name
      - author
    sort:
      - property: nums
        direction: ASC
    image: note.coverUrl
    imageFit: contain
    imageAspectRatio: 1.4
  - type: cards
    name: 뷰
